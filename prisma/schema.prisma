generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String     @id @default(uuid())
  email              String     @unique
  name               String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  googleAccessToken  String?
  googleRefreshToken String?
  googleTokenExpiry  DateTime?
  forms              Form[]
  aiUsage            AIUsage[]
}

model Form {
  id                        String       @id @default(cuid())
  title                     String
  description               String?
  userId                    String
  fields                    Json
  published                 Boolean      @default(false)
  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt
  multiStepEnabled          Boolean      @default(false)
  steps                     Json?
  webhookUrl                String?
  webhookEnabled            Boolean      @default(false)
  webhookSecret             String?
  emailNotificationsEnabled Boolean      @default(false)
  emailRecipients           String[]     @default([])
  emailTemplate             String?
  successMessage            String?
  redirectUrl               String?
  opensAt                   DateTime?
  closesAt                  DateTime?
  maxResponses              Int?
  googleSheetsEnabled       Boolean      @default(false)
  googleSheetId             String?
  googleSheetTab            String?
  user                      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  responses                 Response[]
  webhookLogs               WebhookLog[]

  @@index([userId])
}

model Response {
  id             String    @id @default(uuid())
  formId         String
  data           Json
  createdAt      DateTime  @default(now())
  startedAt      DateTime?
  completedAt    DateTime  @default(now())
  completionTime Int?
  abandoned      Boolean   @default(false)
  currentPage    Int?
  form           Form      @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId])
}

model WebhookLog {
  id        String   @id @default(uuid())
  formId    String
  status    String
  payload   Json
  response  Json?
  attempts  Int      @default(0)
  error     String?
  createdAt DateTime @default(now())
  form      Form     @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId])
  @@index([status])
}

model AIUsage {
  id         String   @id @default(uuid())
  userId     String
  feature    String   // 'generate-form', 'translate', 'analyze-responses', etc.
  tokensUsed Int
  cost       Float    // in USD
  metadata   Json?    // additional context (description, language, etc.)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([feature])
  @@index([createdAt])
}
